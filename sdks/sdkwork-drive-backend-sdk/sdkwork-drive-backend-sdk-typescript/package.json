{
  "name": "@sdkwork/drive-backend-sdk",
  "version": "0.1.0",
  "description": "SDKWork Drive Backend SDK composed facade.",
  "type": "module",
  "private": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "composed",
    "generated/server-openapi/dist",
    "generated/server-openapi/src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./generated": {
      "types": "./generated/server-openapi/src/index.ts",
      "import": "./generated/server-openapi/src/index.ts",
      "default": "./generated/server-openapi/src/index.ts"
    }
  },
  "dependencies": {
    "@sdkwork/sdk-common": "^1.0.2"
  },
  "peerDependencies": {
    "@sdkwork/iam-backend-sdk": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@sdkwork/iam-backend-sdk": {
      "optional": true
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "keywords": [
    "sdkwork",
    "drive",
    "backend-sdk"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
