        "properties": {
          "id": {
            "type": "string"
          },
          "providerKind": {
            "type": "string",
            "enum": [
              "local_filesystem",
              "s3_compatible",
              "azure_blob",
              "google_cloud_storage",
              "aliyun_oss"
            ],
            "pattern": "^(local_filesystem|s3_compatible|azure_blob|google_cloud_storage|aliyun_oss|custom:[a-z0-9_-]{2,32})$"
          },
          "name": {
            "type": "string"
          },
          "endpointUrl": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "bucket": {
            "type": "string"
          },
          "pathStyle": {
            "type": "boolean"
          },
          "credentialRef": {
            "type": "string"
          },
          "serverSideEncryptionMode": {
