          "name": {
            "type": "string"
          },
          "endpointUrl": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "bucket": {
            "type": "string"
          },
          "pathStyle": {
            "type": "boolean"
          },
          "credentialRef": {
            "type": "string"
          },
          "serverSideEncryptionMode": {
