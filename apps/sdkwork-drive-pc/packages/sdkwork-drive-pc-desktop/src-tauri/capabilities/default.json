{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Least-privilege SDKWork Drive desktop renderer permissions.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "allow-window-control",
    "allow-local-filesystem-list",
    "allow-local-filesystem-open",
    "allow-local-upload-pick-files",
    "allow-local-upload-describe-file",
    "allow-local-upload-read-range",
    "allow-local-upload-checksum-file"
  ]
}
