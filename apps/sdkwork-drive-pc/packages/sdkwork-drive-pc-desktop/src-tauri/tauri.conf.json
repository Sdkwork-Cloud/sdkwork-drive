{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDKWork Drive",
  "version": "0.1.0",
  "identifier": "com.sdkwork.drive.pc",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. dev",
    "beforeBuildCommand": "pnpm --dir ../.. build",
    "devUrl": "http://localhost:5183",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SDKWork Drive",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://127.0.0.1:* http://localhost:*; img-src 'self' data: blob: https:; media-src 'self' blob: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "publisher": "SDKWork",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
