{
  "name": "@sdkwork/drive-pc-sandbox-explorer-sdk-adapter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Drive app SDK adapter for the reusable PC sandbox explorer port.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@sdkwork/utils": "workspace:*",
    "@sdkwork/drive-pc-sandbox-contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "sdkwork": {
    "architecture": "pc",
    "capability": "sandbox-explorer-sdk-adapter",
    "domain": "drive",
    "packageType": "sdk-adapter-package",
