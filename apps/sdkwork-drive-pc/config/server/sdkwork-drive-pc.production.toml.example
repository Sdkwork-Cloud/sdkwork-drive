[runtime]
environment = "production"
config_profile = "prod"
build_mode = "production"
deployment_mode = "server"
runtime_target = "server"
app_key = "sdkwork-drive-pc"

[server]
bind = "0.0.0.0:18080"
external_scheme = "https"
trust_forwarded_headers = true

[database]
engine = "postgresql"
host = "db.internal"
port = 5432
database = "sdkwork"
schema = "public"
username = "sdkwork"
password_file = "/etc/sdkwork/sdkwork-drive-pc/database.secret"
ssl_mode = "require"
max_connections = 32

[redis]
enabled = true
host = "redis.internal"
port = 6379
database = 0
password_file = "/etc/sdkwork/sdkwork-drive-pc/redis.secret"
key_prefix = "sdkwork-drive-pc"
