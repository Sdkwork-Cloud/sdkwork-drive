{
  "name": "sdkwork-drive-pc",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev:desktop": "pnpm --filter sdkwork-drive-pc-desktop dev:desktop",
    "build:desktop": "pnpm --filter sdkwork-drive-pc-desktop build:desktop",
    "build:desktop:local": "pnpm --filter sdkwork-drive-pc-desktop build:desktop:local",
    "build:standalone": "node ../../scripts/sdkwork-command.mjs build --deployment-profile standalone",
    "build:debug": "node ../../scripts/drive-build.mjs --deployment-profile standalone --debug"
  },
  "dependencies": {
    "@sdkwork/iam-app-sdk": "workspace:*",
    "@sdkwork/iam-contracts": "workspace:*",
    "@sdkwork/appbase-pc-react": "workspace:*",
    "@sdkwork/auth-pc-react": "workspace:*",
    "@sdkwork/auth-runtime-pc-react": "workspace:*",
    "@sdkwork/drive-admin-storage-sdk": "workspace:*",
    "@sdkwork/drive-app-sdk": "workspace:*",
    "@sdkwork/i18n-pc-react": "workspace:*",
    "@sdkwork/ui-pc-react": "workspace:*",
    "@sdkwork/utils": "workspace:*",
    "lucide-react": "catalog:",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.17.0",
    "sdkwork-drive-pc-admin-core": "workspace:*",
    "sdkwork-drive-pc-admin-storage-providers": "workspace:*",
    "sdkwork-drive-pc-admin-operations": "workspace:*",
    "sdkwork-drive-pc-commons": "workspace:*",
    "sdkwork-drive-pc-core": "workspace:*",
    "sdkwork-drive-pc-file": "workspace:*",
    "sdkwork-drive-pc-transfer": "workspace:*",
    "sdkwork-drive-pc-types": "workspace:*"
  },
  "peerDependencies": {
    "@sdkwork/iam-app-sdk": "*",
    "@sdkwork/appbase-pc-react": "*",
    "@sdkwork/auth-pc-react": "*"
  },
  "peerDependenciesMeta": {
    "@sdkwork/iam-app-sdk": {
      "optional": true
    },
    "@sdkwork/appbase-pc-react": {
      "optional": true
    },
    "@sdkwork/auth-pc-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.2.6"
  }
}
