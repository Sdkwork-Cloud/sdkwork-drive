# SDKWork Drive PC public Vite defaults.
# VITE_* values are browser-visible and must never contain tokens or secrets.

VITE_DRIVE_PC_ENVIRONMENT=development
VITE_DRIVE_PC_CONFIG_PROFILE=dev
VITE_DRIVE_PC_BUILD_MODE=development
VITE_DRIVE_PC_DEPLOYMENT_MODE=local
VITE_DRIVE_PC_RUNTIME_TARGET=browser

# API Gateway base URL - all API calls go through the gateway
VITE_DRIVE_PC_API_GATEWAY_BASE_URL=http://127.0.0.1:3900

# In Vite development mode, route SDK calls through the dev-server proxy instead of
# cross-origin requests to 127.0.0.1. drive-dev.mjs sets this automatically.
# VITE_DRIVE_PC_DEV_SAME_ORIGIN_API=true

# Surface-specific SDK base URLs (relative to API gateway)
VITE_DRIVE_PC_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_BACKEND_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_DRIVE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_DRIVE_ADMIN_STORAGE_API_BASE_URL=http://127.0.0.1:3900

# TokenManager behavior only; live tokens are runtime session state.
VITE_DRIVE_PC_TOKEN_MANAGER_MODE=appbase-global
VITE_DRIVE_PC_TOKEN_STORAGE=browser-local
