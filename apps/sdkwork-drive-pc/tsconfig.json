    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "sdkwork-drive-pc-types": [
        "./packages/sdkwork-drive-pc-types/src"
      ],
      "sdkwork-drive-pc-commons": [
        "./packages/sdkwork-drive-pc-commons/src"
      ],
      "sdkwork-drive-pc-file": [
        "./packages/sdkwork-drive-pc-file/src"
      ],
      "sdkwork-drive-pc-transfer": [
        "./packages/sdkwork-drive-pc-transfer/src"
      ],
      "sdkwork-drive-pc-core": [
        "./packages/sdkwork-drive-pc-core/src"
      ],
      "sdkwork-drive-pc-core/types": [
        "./packages/sdkwork-drive-pc-core/src/types/index.ts"
      ],
      "sdkwork-drive-pc-drive": [
        "./packages/sdkwork-drive-pc-drive/src"
      ],
      "sdkwork-drive-pc-admin-core": [
        "./packages/sdkwork-drive-pc-admin-core/src"
      ],
      "sdkwork-drive-pc-admin-storage-providers": [
        "./packages/sdkwork-drive-pc-admin-storage-providers/src"
      ],
      "sdkwork-drive-pc-admin-operations": [
        "./packages/sdkwork-drive-pc-admin-operations/src"
