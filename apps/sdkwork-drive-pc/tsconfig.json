      "@sdkwork/utils": [
        "../../../sdkwork-utils/packages/sdkwork-utils-typescript/dist/index.d.ts"
      ],
      "@sdkwork/ui-pc-react": [
        "../../../sdkwork-ui/sdkwork-ui-pc-react/src/index.ts"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "packages/**/src-tauri/target/**",
    "packages/**/src-tauri/target-test-migrate/**"
  ]
}
