# SDKWork Drive local PostgreSQL development profile.
# Copy to .env.postgres for host-local overrides. Do not commit .env.postgres.
#
# IAM login (OAuth/device flow) uses this PostgreSQL instance even when Drive desktop
# dev runs with SQLite for file metadata. Keep these values aligned with
# ../sdkwork-claw-router/.env.postgres so both apps share the same dev database.
#
# When SDKWORK_IAM_DATABASE_URL is unset, scripts/drive-dev.mjs and
# scripts/gateway-standalone-run.mjs map SDKWORK_DRIVE_DATABASE_* (and SDKWORK_CLAW_*)
# for IAM.

SDKWORK_DRIVE_DATABASE_ENGINE=postgresql
SDKWORK_DRIVE_DATABASE_HOST=127.0.0.1
SDKWORK_DRIVE_DATABASE_PORT=5432
SDKWORK_DRIVE_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_DRIVE_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_DRIVE_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_DRIVE_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_DRIVE_DATABASE_SSL_MODE=disable
SDKWORK_DRIVE_DATABASE_MAX_CONNECTIONS=32

# Mirror claw-router keys so embedded IAM reads the same profile directly.
SDKWORK_CLAW_DATABASE_ENGINE=postgresql
SDKWORK_CLAW_DATABASE_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_PORT=5432
SDKWORK_CLAW_DATABASE_NAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_SCHEMA=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_USERNAME=sdkwork_ai_dev
SDKWORK_CLAW_DATABASE_PASSWORD=sdkworkdev123
SDKWORK_CLAW_DATABASE_SSL_MODE=disable
SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS=32

# Optional: direct app connection URL. If set, it takes precedence over split app fields.
# SDKWORK_DRIVE_DATABASE_URL=postgresql://sdkwork_ai_dev:sdkworkdev123@127.0.0.1:5432/sdkwork_ai_dev?sslmode=disable

# Required for database init when creating roles/databases needs an admin connection.
SDKWORK_DRIVE_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_DRIVE_DATABASE_ADMIN_PORT=5432
SDKWORK_DRIVE_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_DRIVE_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_DRIVE_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_DRIVE_DATABASE_ADMIN_SSL_MODE=disable

SDKWORK_CLAW_DATABASE_ADMIN_HOST=127.0.0.1
SDKWORK_CLAW_DATABASE_ADMIN_PORT=5432
SDKWORK_CLAW_DATABASE_ADMIN_USERNAME=postgres
SDKWORK_CLAW_DATABASE_ADMIN_PASSWORD=postgres_admin_pass
SDKWORK_CLAW_DATABASE_ADMIN_DATABASE=postgres
SDKWORK_CLAW_DATABASE_ADMIN_SSL_MODE=disable

# Runtime policy (development defaults)
SDKWORK_DRIVE_RUNTIME_PROFILE=development
SDKWORK_DRIVE_UPLOAD_CONTENT_POLICY_MODE=audit

# Production JWT verification (optional; unset keeps unsigned inline dev tokens)
# SDKWORK_DRIVE_JWT_HMAC_SECRET=replace-with-hmac-secret
# SDKWORK_DRIVE_JWT_HMAC_SECRETS_JSON={"default":"secret-a","tenant-a":"secret-b"}
# SDKWORK_DRIVE_JWT_JWKS_JSON={"keys":[{"kty":"RSA","kid":"iam-default","n":"...","e":"AQAB"}]}
# SDKWORK_DRIVE_JWT_JWKS_URL=http://127.0.0.1:3900/app/v3/api/iam/.well-known/jwks.json
# SDKWORK_DRIVE_JWT_JWKS_REFRESH_SECONDS=300
