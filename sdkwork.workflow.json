{
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-drive",
    "name": "SDKWork Drive",
    "repository": "Sdkwork-Cloud/sdkwork-drive",
    "sourcePath": ".",
    "configPath": "sdkwork.app.config.json"
  },
  "release": {
    "artifactPrefix": "sdkwork-drive",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "auto",
      "maxCommitSubjects": 50
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "ref": "b74a1413d387c803b524df96dc150fb02ce8c25f",
      "refInput": "SDKWORK_APPBASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-ui",
      "repository": "Sdkwork-Cloud/sdkwork-ui",
      "ref": "e2dea9c788f93c3a59d25c1791c7bb8c0ad0bb38",
      "refInput": "SDKWORK_UI_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-commons",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-commons",
      "ref": "c9adc5a02fed0d9ce70ab719e5d2155ed40676da",
      "refInput": "SDKWORK_SDK_COMMONS_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "ref": "0b0e984ffbdec49a28c2da3edebcdddab4087e62",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-database",
      "repository": "Sdkwork-Cloud/sdkwork-database",
      "ref": "main",
      "refInput": "SDKWORK_DATABASE_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-id",
      "repository": "Sdkwork-Cloud/sdkwork-id",
      "ref": "main",
      "refInput": "SDKWORK_ID_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-web-framework",
      "repository": "Sdkwork-Cloud/sdkwork-web-framework",
      "ref": "main",
      "refInput": "SDKWORK_WEB_FRAMEWORK_REF",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.33.0",
    "rust": "stable"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install workspace dependencies",
        "shell": "pwsh",
        "run": "pnpm install --no-frozen-lockfile"
      }
    ],
    "build": [
      {
        "name": "Run SDKWork Drive contract checks",
        "shell": "pwsh",
        "run": "pnpm run verify"
      }
    ],
    "package": [
      {
        "name": "Package gateway server archive",
        "shell": "pwsh",
        "run": "$ErrorActionPreference = \"Stop\"\nswitch ($env:SDKWORK_PACKAGE_PROFILE) {\n  'standalone' { pnpm gateway:standalone:pack }\n  'cloud-config' { pnpm gateway:cloud:bundle }\n  default { Write-Host \"Skipping gateway archive for profile $($env:SDKWORK_PACKAGE_PROFILE)\" }\n}"
      },
      {
        "name": "Write package evidence manifest",
        "shell": "pwsh",
        "run": "$ErrorActionPreference = \"Stop\"\nNew-Item -ItemType Directory -Force -Path \"artifacts/release\" | Out-Null\nnode tools/generate_release_sbom.mjs artifacts/release/sbom.sdkwork-drive.json\n$manifest = [ordered]@{\n  appId = $env:SDKWORK_APP_ID\n  packageId = $env:SDKWORK_PACKAGE_ID\n  packageVersion = $env:SDKWORK_PACKAGE_VERSION\n  targetId = $env:SDKWORK_PACKAGE_TARGET_ID\n  dependencyWorkspace = \"..\"\n  sbomPath = \"artifacts/release/sbom.sdkwork-drive.json\"\n}\n$manifest | ConvertTo-Json -Depth 5 | Set-Content -Path \"artifacts/release/sdkwork-drive-$env:SDKWORK_PACKAGE_ID.json\" -Encoding utf8"
      }
    ],
    "validate": [
      {
        "name": "Validate gateway server archive",
        "shell": "pwsh",
        "run": "$ErrorActionPreference = \"Stop\"\nswitch ($env:SDKWORK_PACKAGE_PROFILE) {\n  'standalone' { pnpm gateway:standalone:pack:validate }\n  'cloud-config' { pnpm gateway:cloud:bundle:validate }\n  default { Write-Host \"Skipping gateway archive validation for profile $($env:SDKWORK_PACKAGE_PROFILE)\" }\n}"
      },
      {
        "name": "Validate package evidence",
        "shell": "pwsh",
        "run": "$ErrorActionPreference = \"Stop\"\nif (-not (Test-Path \"artifacts/release/sdkwork-drive-$env:SDKWORK_PACKAGE_ID.json\")) {\n  throw \"Missing package evidence manifest for $env:SDKWORK_PACKAGE_ID\"\n}\nif (-not (Test-Path \"artifacts/release/sbom.sdkwork-drive.json\")) {\n  throw \"Missing SBOM artifact at artifacts/release/sbom.sdkwork-drive.json\"\n}"
      }
    ]
  },
  "targets": [
    {
      "id": "linux-x64-server-tar-gz",
      "profile": "server",
      "platform": "linux",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["artifacts/release/**/*"]
    },
    {
      "id": "linux-x64-standalone-gateway-tar-gz",
      "profile": "standalone",
      "platform": "linux",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-linux-x64-standalone-gateway.tar.gz"]
    },
    {
      "id": "linux-arm64-standalone-gateway-tar-gz",
      "profile": "standalone",
      "platform": "linux",
      "architecture": "arm64",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-linux-arm64-standalone-gateway.tar.gz"]
    },
    {
      "id": "windows-x64-standalone-gateway-tar-gz",
      "profile": "standalone",
      "platform": "windows",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "windows-latest",
      "outputGlobs": ["dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-windows-x64-standalone-gateway.tar.gz"]
    },
    {
      "id": "windows-arm64-standalone-gateway-tar-gz",
      "profile": "standalone",
      "platform": "windows",
      "architecture": "arm64",
      "formats": ["tar.gz"],
      "runner": "windows-latest",
      "outputGlobs": ["dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-windows-arm64-standalone-gateway.tar.gz"]
    },
    {
      "id": "macos-x64-standalone-gateway-tar-gz",
      "profile": "standalone",
      "platform": "macos",
      "architecture": "x64",
      "formats": ["tar.gz"],
      "runner": "macos-14",
      "outputGlobs": ["dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-macos-x64-standalone-gateway.tar.gz"]
    },
    {
      "id": "macos-arm64-standalone-gateway-tar-gz",
      "profile": "standalone",
      "platform": "macos",
      "architecture": "arm64",
      "formats": ["tar.gz"],
      "runner": "macos-14",
      "outputGlobs": ["dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-macos-arm64-standalone-gateway.tar.gz"]
    },
    {
      "id": "cloud-config-bundle-tar-gz",
      "profile": "cloud-config",
      "platform": "all",
      "architecture": "all",
      "formats": ["tar.gz"],
      "runner": "ubuntu-24.04",
      "outputGlobs": ["dist/cloud-config/sdkwork-drive-api-gateway-config-*.tar.gz"]
    }
  ],
  "security": {
    "artifactAttestations": true,
    "sbomRequired": true,
    "signingRequired": false
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": false,
    "retentionDays": 30
  }
}
