# syntax=docker/dockerfile:1.7

FROM rust:1-bookworm AS builder
WORKDIR /src
COPY . .
RUN cargo build --release -p sdkwork-router-drive-app-api

FROM debian:bookworm-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libssl3 \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /src/target/release/sdkwork-router-drive-app-api /app/sdkwork-router-drive-app-api
ENV SDKWORK_DRIVE_RUNTIME_PROFILE=production
ENV SDKWORK_DRIVE_APP_API_BIND=0.0.0.0:18080
EXPOSE 18080
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget -qO- http://127.0.0.1:18080/healthz || exit 1
ENTRYPOINT ["/app/sdkwork-router-drive-app-api"]
