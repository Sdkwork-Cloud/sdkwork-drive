{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDKWork Drive",
  "version": "0.1.0",
  "identifier": "com.sdkwork.drive.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:tauri",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SDKWork Drive",
        "width": 1440,
        "height": 920,
        "minWidth": 1240,
        "minHeight": 760,
        "visible": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
