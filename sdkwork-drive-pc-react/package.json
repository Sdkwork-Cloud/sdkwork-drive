{
  "name": "@sdkwork/drive-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:web",
    "dev:web": "pnpm --filter @sdkwork/drive-web dev",
    "dev:desktop": "pnpm --filter @sdkwork/drive-desktop dev",
    "build": "pnpm run build:web && pnpm run build:desktop",
    "build:web": "pnpm --filter @sdkwork/drive-web build",
    "build:desktop": "pnpm --filter @sdkwork/drive-desktop build",
    "check:structure": "node scripts/check-sdkwork-drive-structure.mjs",
    "test:structure": "node --test scripts/check-sdkwork-drive-structure.test.mjs scripts/sdkwork-drive-desktop-structure.test.mjs scripts/sdkwork-drive-desktop-release.test.mjs scripts/sdkwork-drive-tauri-dev-command.test.mjs scripts/sdkwork-drive-release-workspace.test.mjs scripts/sdkwork-drive-release-sdks.test.mjs",
    "test:packages": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "prepare:release-workspace": "node scripts/prepare-sdkwork-drive-release-workspace.mjs",
    "prepare:release-sdk-sources": "node scripts/materialize-sdkwork-drive-release-sdks.mjs",
    "prepare:release-sdk-builds": "node scripts/build-sdkwork-drive-release-sdks.mjs",
    "tauri:dev": "pnpm --filter @sdkwork/drive-desktop tauri:dev",
    "tauri:build": "pnpm --filter @sdkwork/drive-desktop tauri:build",
    "tauri:info": "pnpm --filter @sdkwork/drive-desktop tauri:info",
    "release:desktop": "node scripts/run-sdkwork-drive-desktop-release.mjs",
    "release:desktop:list-targets": "node scripts/run-sdkwork-drive-desktop-release.mjs --list-targets",
    "release:desktop:windows:x64": "node scripts/run-sdkwork-drive-desktop-release.mjs --platform windows --arch x64",
    "release:desktop:windows:arm64": "node scripts/run-sdkwork-drive-desktop-release.mjs --platform windows --arch arm64",
    "release:desktop:linux:x64": "node scripts/run-sdkwork-drive-desktop-release.mjs --platform linux --arch x64",
    "release:desktop:linux:arm64": "node scripts/run-sdkwork-drive-desktop-release.mjs --platform linux --arch arm64",
    "release:desktop:macos:x64": "node scripts/run-sdkwork-drive-desktop-release.mjs --platform macos --arch x64",
    "release:desktop:macos:arm64": "node scripts/run-sdkwork-drive-desktop-release.mjs --platform macos --arch arm64",
    "test": "pnpm check:structure && pnpm test:structure && pnpm test:packages",
    "clean": "pnpm -r --if-present clean"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "turbo": "^2.5.6",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
