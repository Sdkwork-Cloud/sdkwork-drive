# Drive topology profile: self-hosted + unified-process + production (on-prem gateway desktop builds)

SDKWORK_DRIVE_HOSTING=self-hosted
SDKWORK_DRIVE_SERVICE_LAYOUT=unified-process
SDKWORK_DRIVE_ENVIRONMENT=production
SDKWORK_DRIVE_PROFILE_ID=self-hosted.unified-process.production

SDKWORK_DRIVE_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:3900
SDKWORK_DRIVE_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:3900
SDKWORK_DRIVE_STANDALONE_GATEWAY_ENVIRONMENT=production

VITE_DRIVE_PC_HOSTING=self-hosted
VITE_DRIVE_PC_ENVIRONMENT=production
VITE_DRIVE_PC_CONFIG_PROFILE=prod
VITE_DRIVE_PC_BUILD_MODE=production
VITE_DRIVE_PC_DEPLOYMENT_MODE=local
VITE_DRIVE_PC_RUNTIME_TARGET=desktop

VITE_DRIVE_PC_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_APPBASE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_DRIVE_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_APP_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_DRIVE_ADMIN_STORAGE_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_BACKEND_API_BASE_URL=http://127.0.0.1:3900
VITE_DRIVE_PC_TOKEN_MANAGER_MODE=appbase-global
VITE_DRIVE_PC_TOKEN_STORAGE=os-secure-storage
