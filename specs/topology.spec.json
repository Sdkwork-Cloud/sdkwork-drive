{
    "schemaVersion":  2,
    "kind":  "sdkwork.app.topology",
    "appId":  "sdkwork-drive",
    "archetype":  "application-http-gateway",
    "profileRoot":  "configs/topology",
    "profilePattern":  "{hosting}.{serviceLayout}.{environment}.env",
    "vocabulary":  {
                       "hosting":  {
                                       "allowed":  [
                                                       "self-hosted",
                                                       "cloud-hosted"
                                                   ]
                                   },
                       "serviceLayout":  {
                                             "allowed":  [
                                                             "unified-process",
                                                             "split-services"
                                                         ]
                                         },
                       "environment":  {
                                           "allowed":  [
                                                           "development",
                                                           "production"
                                                       ]
                                       }
                   },
    "defaults":  {
                     "developmentProfileId":  "self-hosted.unified-process.development",
                     "productionProfileId":  "cloud-hosted.split-services.production",
                     "desktopBuildProfileId":  "cloud-hosted.split-services.production",
                     "gatewayBind":  "127.0.0.1:3900"
                 },
    "profileFiles":  {
                         "self-hosted.unified-process.development":  "configs/topology/self-hosted.unified-process.development.env",
                         "self-hosted.split-services.development":  "configs/topology/self-hosted.split-services.development.env",
                         "self-hosted.unified-process.production":  "configs/topology/self-hosted.unified-process.production.env",
                         "cloud-hosted.split-services.development":  "configs/topology/cloud-hosted.split-services.development.env",
                         "cloud-hosted.split-services.production":  "configs/topology/cloud-hosted.split-services.production.env"
                     },
    "envKeys":  {
                    "hosting":  "SDKWORK_DRIVE_HOSTING",
                    "serviceLayout":  "SDKWORK_DRIVE_SERVICE_LAYOUT",
                    "environment":  "SDKWORK_DRIVE_ENVIRONMENT",
                    "profileId":  "SDKWORK_DRIVE_PROFILE_ID",
                    "clientHosting":  "VITE_DRIVE_PC_HOSTING",
                    "gatewayAutostart":  "SDKWORK_DRIVE_PLATFORM_API_GATEWAY_AUTOSTART",
                    "standaloneGatewayBind":  "SDKWORK_DRIVE_APPLICATION_PUBLIC_INGRESS_BIND",
                    "standaloneGatewayConfig":  "SDKWORK_DRIVE_STANDALONE_GATEWAY_CONFIG",
                    "standaloneGatewayEnvironment":  "SDKWORK_DRIVE_STANDALONE_GATEWAY_ENVIRONMENT",
                    "cloudGatewayBind":  "SDKWORK_API_GATEWAY_BIND",
                    "cloudGatewayConfig":  "SDKWORK_API_GATEWAY_CONFIG",
                    "clientApiGatewayBaseUrl":  "VITE_DRIVE_PC_PLATFORM_API_GATEWAY_HTTP_URL",
                    "apiGatewayBaseUrl":  "SDKWORK_DRIVE_PLATFORM_API_GATEWAY_HTTP_URL"
                },
    "surfaces":  {
                     "application.public-ingress":  {
                                                        "connectivityPlane":  "application",
                                                        "protocols":  [
                                                                          "http"
                                                                      ],
                                                        "bindEnv":  "SDKWORK_DRIVE_APPLICATION_PUBLIC_INGRESS_BIND",
                                                        "httpUrlEnv":  "SDKWORK_DRIVE_APPLICATION_PUBLIC_HTTP_URL",
                                                        "clientHttpEnv":  "VITE_DRIVE_PC_APPLICATION_PUBLIC_HTTP_URL"
                                                    },
                     "platform.api-gateway":  {
                                                  "connectivityPlane":  "platform",
                                                  "protocols":  [
                                                                    "http"
                                                                ],
                                                  "owner":  "sdkwork-api-gateway",
                                                  "bindEnv":  "SDKWORK_API_GATEWAY_BIND",
                                                  "httpUrlEnv":  "SDKWORK_DRIVE_PLATFORM_API_GATEWAY_HTTP_URL",
                                                  "clientHttpEnv":  "VITE_DRIVE_PC_PLATFORM_API_GATEWAY_HTTP_URL",
                                                  "autostartEnv":  "SDKWORK_DRIVE_PLATFORM_API_GATEWAY_AUTOSTART"
                                              }
                 },
    "cloudPublicHosts":  {
                             "application.public-ingress":  {
                                                                "httpHost":  "drive.sdkwork.com"
                                                            },
                             "platform.api-gateway":  {
                                                          "httpHost":  "api.sdkwork.com"
                                                      }
                         },
    "database":  {
                     "appPrefix":  "SDKWORK_DRIVE"
                 },
    "components":  {
                       "standaloneGateway":  {
                                                 "crate":  "sdkwork-drive-standalone-gateway",
                                                 "binary":  "sdkwork-drive-standalone-gateway",
                                                 "configGlob":  "configs/sdkwork-drive-standalone-gateway.{profile}.toml"
                                             },
                       "cloudGateway":  {
                                            "crate":  "sdkwork-api-gateway-api-server",
                                            "binary":  "sdkwork-api-gateway",
                                            "repository":  "sdkwork-api-gateway",
                                            "configGlob":  "configs/sdkwork-api-gateway.drive.{profile}.toml"
                                        }
                   },
    "orchestration":  {
                          "profiles":  {
                                           "self-hosted.unified-process.development":  {
                                                                                           "processes":  [
                                                                                                             {
                                                                                                                 "id":  "application.public-ingress",
                                                                                                                 "binary":  "sdkwork-drive-standalone-gateway",
                                                                                                                 "required":  true
                                                                                                             },
                                                                                                             {
                                                                                                                 "id":  "pc-renderer",
                                                                                                                 "package":  "apps/sdkwork-drive-pc",
                                                                                                                 "script":  "dev",
                                                                                                                 "required":  true
                                                                                                             }
                                                                                                         ],
                                                                                           "healthSurfaces":  [
                                                                                                                  "application.public-ingress"
                                                                                                              ]
                                                                                       },
                                           "self-hosted.split-services.development":  {
                                                                                          "processes":  [
                                                                                                            {
                                                                                                                "id":  "application.public-ingress",
                                                                                                                "binary":  "sdkwork-drive-standalone-gateway",
                                                                                                                "required":  true
                                                                                                            },
                                                                                                            {
                                                                                                                "id":  "pc-renderer",
                                                                                                                "package":  "apps/sdkwork-drive-pc",
                                                                                                                "script":  "dev",
                                                                                                                "required":  true
                                                                                                            }
                                                                                                        ],
                                                                                          "healthSurfaces":  [
                                                                                                                 "application.public-ingress"
                                                                                                             ]
                                                                                      },
                                           "cloud-hosted.split-services.development":  {
                                                                                           "processes":  [
                                                                                                             {
                                                                                                                 "id":  "platform.api-gateway",
                                                                                                                 "binary":  "sdkwork-api-gateway",
                                                                                                                 "repository":  "sdkwork-api-gateway",
                                                                                                                 "required":  true
                                                                                                             },
                                                                                                             {
                                                                                                                 "id":  "drive-app-api",
                                                                                                                 "binary":  "sdkwork-router-drive-app-api",
                                                                                                                 "required":  true
                                                                                                             },
                                                                                                             {
                                                                                                                 "id":  "pc-renderer",
                                                                                                                 "package":  "apps/sdkwork-drive-pc",
                                                                                                                 "script":  "dev",
                                                                                                                 "required":  true
                                                                                                             }
                                                                                                         ],
                                                                                           "healthSurfaces":  [
                                                                                                                  "platform.api-gateway"
                                                                                                              ]
                                                                                       }
                                       }
                      },
    "packaging":  {
                      "cloudConfigFiles":  [
                                               "sdkwork-api-gateway.drive.development.toml",
                                               "sdkwork-api-gateway.drive.production.toml"
                                           ],
                      "targets":  [
                                      {
                                          "id":  "linux-x64-application-public-ingress-tar-gz",
                                          "profile":  "application-public-ingress",
                                          "platform":  "linux",
                                          "architecture":  "x64",
                                          "formats":  [
                                                          "tar.gz"
                                                      ],
                                          "runner":  "ubuntu-24.04",
                                          "rustTarget":  "x86_64-unknown-linux-gnu",
                                          "outputGlob":  "dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-linux-x64-standalone-gateway.tar.gz"
                                      },
                                      {
                                          "id":  "linux-arm64-application-public-ingress-tar-gz",
                                          "profile":  "application-public-ingress",
                                          "platform":  "linux",
                                          "architecture":  "arm64",
                                          "formats":  [
                                                          "tar.gz"
                                                      ],
                                          "runner":  "ubuntu-24.04",
                                          "rustTarget":  "aarch64-unknown-linux-gnu",
                                          "outputGlob":  "dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-linux-arm64-standalone-gateway.tar.gz"
                                      },
                                      {
                                          "id":  "windows-x64-application-public-ingress-tar-gz",
                                          "profile":  "application-public-ingress",
                                          "platform":  "windows",
                                          "architecture":  "x64",
                                          "formats":  [
                                                          "tar.gz"
                                                      ],
                                          "runner":  "windows-latest",
                                          "rustTarget":  "x86_64-pc-windows-msvc",
                                          "outputGlob":  "dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-windows-x64-standalone-gateway.tar.gz"
                                      },
                                      {
                                          "id":  "windows-arm64-application-public-ingress-tar-gz",
                                          "profile":  "application-public-ingress",
                                          "platform":  "windows",
                                          "architecture":  "arm64",
                                          "formats":  [
                                                          "tar.gz"
                                                      ],
                                          "runner":  "windows-latest",
                                          "rustTarget":  "aarch64-pc-windows-msvc",
                                          "outputGlob":  "dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-windows-arm64-standalone-gateway.tar.gz"
                                      },
                                      {
                                          "id":  "macos-x64-application-public-ingress-tar-gz",
                                          "profile":  "application-public-ingress",
                                          "platform":  "macos",
                                          "architecture":  "x64",
                                          "formats":  [
                                                          "tar.gz"
                                                      ],
                                          "runner":  "macos-14",
                                          "rustTarget":  "x86_64-apple-darwin",
                                          "outputGlob":  "dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-macos-x64-standalone-gateway.tar.gz"
                                      },
                                      {
                                          "id":  "macos-arm64-application-public-ingress-tar-gz",
                                          "profile":  "application-public-ingress",
                                          "platform":  "macos",
                                          "architecture":  "arm64",
                                          "formats":  [
                                                          "tar.gz"
                                                      ],
                                          "runner":  "macos-14",
                                          "rustTarget":  "aarch64-apple-darwin",
                                          "outputGlob":  "dist/standalone-gateway/sdkwork-drive-standalone-gateway-*-macos-arm64-standalone-gateway.tar.gz"
                                      },
                                      {
                                          "id":  "platform-config-bundle-tar-gz",
                                          "profile":  "platform-config-bundle",
                                          "platform":  "all",
                                          "architecture":  "all",
                                          "formats":  [
                                                          "tar.gz"
                                                      ],
                                          "runner":  "ubuntu-24.04",
                                          "outputGlob":  "dist/cloud-config/sdkwork-drive-api-gateway-config-*.tar.gz"
                                      }
                                  ]
                  },
    "scripts":  {
                    "driveDev":  "scripts/drive-dev.mjs",
                    "driveBuild":  "scripts/drive-build.mjs",
                    "gatewayStandaloneRun":  "scripts/gateway-standalone-run.mjs",
                    "gatewayStandalonePack":  "scripts/gateway-standalone-pack.mjs",
                    "gatewayCloudBundle":  "scripts/gateway-cloud-bundle.mjs"
                },
    "retired":  {
                    "vocabulary":  {
                                       "topology":  [
                                                        "standalone",
                                                        "cloud"
                                                    ],
                                       "profile":  [
                                                       "development",
                                                       "production"
                                                   ]
                                   },
                    "envKeys":  [
                                    "SDKWORK_DRIVE_TOPOLOGY",
                                    "VITE_DRIVE_PC_TOPOLOGY",
                                    "VITE_DRIVE_PC_API_GATEWAY_BASE_URL"
                                ],
                    "profileIds":  [
                                       "standalone.development",
                                       "standalone.production",
                                       "cloud.development",
                                       "cloud.production"
                                   ],
                    "packagingProfiles":  [
                                              "standalone",
                                              "cloud-config"
                                          ],
                    "specFiles":  [
                                      "specs/drive-topology.spec.json"
                                  ],
                    "cliFlags":  [
                                     "--topology"
                                 ]
                }
}
