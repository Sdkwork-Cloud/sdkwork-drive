  "processes": [
    {
      "id": "sdkwork-api-drive-standalone-gateway",
      "entrypoint": "crates/sdkwork-api-drive-standalone-gateway/src/main.rs",
      "poolOwner": "crates/sdkwork-drive-workspace-service/src/bootstrap.rs",
      "driver": "sqlx::PgPool",
      "poolCount": 1,
      "databaseUrlEnv": "SDKWORK_CLAW_DATABASE_URL",
      "schemaEnv": "SDKWORK_CLAW_DATABASE_SCHEMA",
      "maxConnectionsEnv": "SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS",
      "productionSourceRoots": [
        "crates/sdkwork-api-drive-standalone-gateway/src",
        "crates/sdkwork-api-drive-assembly/src",
        "crates/sdkwork-drive-workspace-service/src"
      ],
      "consumers": [
        {
          "module": "sdkwork-drive lifecycle and repositories",
          "poolMode": "installed-process-pool",
          "evidence": [
            "crates/sdkwork-drive-workspace-service/src/infrastructure/sql/installer.rs"
          ]
        },
        {
          "module": "sdkwork-iam",
          "poolMode": "installed-process-pool",
          "evidence": [
            "crates/sdkwork-api-drive-standalone-gateway/src/main.rs"
          ]
        }
      ],
      "temporaryDriverExceptions": [
        {
          "driver": "sqlx::AnyPool",
          "owner": "sdkwork-drive maintainers",
          "removalMilestone": "Migrate Drive PostgreSQL repositories to sqlx::PgPool before the next Drive production release",
          "combinedConnectionBudget": "SDKWORK_CLAW_DATABASE_MAX_CONNECTIONS",
          "adr": "docs/architecture/decisions/ADR-20260719-drive-pool-driver-migration.md",
          "evidence": [
            "crates/sdkwork-drive-workspace-service/src/infrastructure/sql/installer.rs"
