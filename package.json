    "_sdkwork:test": "node scripts/sdkwork-command.mjs test",
    "_sdkwork:check": "pnpm run check:app-composition && cargo check --workspace && pnpm check:architecture-alignment && pnpm check:dependency-management && pnpm check:app-sdk-consumers && pnpm check:package-standard && pnpm check:component-spec-standard && pnpm check:pc-standard && pnpm check:docs-standard && pnpm check:pnpm-script-standard && pnpm check:agent-workflow-standard && pnpm check:release-readiness && pnpm test:iam-application-bootstrap-standard && pnpm test:sdkwork-command-dev-topology && node ../sdkwork-specs/tools/audit-iam-embedded-bootstrap-workspace.mjs && pnpm test:staging-admin-smoke-contract && node --test tools/check_drive_deployments.test.mjs && pnpm deploy:validate && pnpm topology:validate && pnpm api:assembly:validate && pnpm db:validate && pnpm db:pool:validate && pnpm api:envelope:check && pnpm api:schema:check",
    "_sdkwork:verify": "node scripts/sdkwork-verify.mjs && pnpm run check:app-composition",
    "_sdkwork:clean": "node scripts/sdkwork-command.mjs clean",
    "_sdkwork:gateway:standalone": "node scripts/gateway-standalone-run.mjs --environment development",
    "_sdkwork:client:browser:standalone": "node scripts/drive-dev.mjs --target browser --client-only --deployment-profile standalone",
    "_sdkwork:client:desktop:standalone": "node scripts/drive-dev.mjs --target desktop --client-only --deployment-profile standalone",
    "_sdkwork:client:browser:cloud": "node scripts/drive-dev.mjs --target browser --client-only --deployment-profile cloud",
    "_sdkwork:client:desktop:cloud": "node scripts/drive-dev.mjs --target desktop --client-only --deployment-profile cloud",
    "typecheck": "pnpm --filter sdkwork-drive-pc typecheck",
    "test:pc": "pnpm --filter sdkwork-drive-pc test",
    "test:app-openapi-context": "node --test scripts/dev/sdkwork-drive-app-openapi-context.test.mjs",
    "test:app-sdk-smoke": "node --test sdks/sdkwork-drive-app-sdk/tests/sdk-family-smoke.test.mjs",
    "test:open-sdk-smoke": "node --test sdks/sdkwork-drive-sdk/tests/sdk-family-smoke.test.mjs",
    "test:backend-sdk-smoke": "node --test sdks/sdkwork-drive-backend-sdk/tests/sdk-family-smoke.test.mjs",
    "test:admin-storage-sdk-smoke": "node --test sdks/sdkwork-drive-admin-storage-sdk/tests/sdk-family-smoke.test.mjs",
    "test:internal-sdk-smoke": "node --test sdks/sdkwork-drive-internal-sdk/tests/sdk-family-smoke.test.mjs",
