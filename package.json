{
  "name": "sdkwork-drive-workspace",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {},
  "scripts": {
    "drive:dev": "node scripts/drive-dev.mjs --target browser --database postgres --hosting self-hosted",
    "drive:dev:sqlite": "node scripts/drive-dev.mjs --target browser --database sqlite --hosting self-hosted",
    "drive:dev:cloud": "node scripts/drive-dev.mjs --target browser --database postgres --hosting cloud-hosted",
    "drive:dev:desktop": "node scripts/drive-dev.mjs --target desktop --database sqlite --hosting self-hosted",
    "drive:dev:desktop:postgres": "node scripts/drive-dev.mjs --target desktop --database postgres --hosting self-hosted",
    "drive:dev:desktop:cloud": "node scripts/drive-dev.mjs --target desktop --database sqlite --hosting cloud-hosted",
    "drive:build": "node scripts/drive-build.mjs --hosting cloud-hosted",
    "drive:build:self-hosted": "node scripts/drive-build.mjs --hosting self-hosted",
    "drive:build:debug": "node scripts/drive-build.mjs --hosting cloud-hosted --debug",
    "gateway:standalone:run": "node scripts/gateway-standalone-run.mjs --environment development",
    "gateway:standalone:run:release": "node scripts/gateway-standalone-run.mjs --environment production --release",
    "gateway:standalone:plan": "node scripts/gateway-standalone-run.mjs --environment development --dry-run",
    "gateway:standalone:build": "cargo build --release -p sdkwork-drive-standalone-gateway --bin sdkwork-drive-standalone-gateway",
    "gateway:standalone:pack": "node scripts/gateway-standalone-pack.mjs package",
    "gateway:standalone:pack:validate": "node scripts/gateway-standalone-pack.mjs validate",
    "gateway:standalone:pack:skip-build": "node scripts/gateway-standalone-pack.mjs package --skip-build",
    "gateway:standalone:matrix": "node scripts/print-gateway-package-matrix.mjs --profile application-public-ingress",
    "gateway:cloud:bundle": "node scripts/gateway-cloud-bundle.mjs bundle",
    "gateway:cloud:bundle:validate": "node scripts/gateway-cloud-bundle.mjs validate",
    "gateway:cloud:matrix": "node scripts/print-gateway-package-matrix.mjs --profile platform-config-bundle",
    "gateway:matrix": "node scripts/print-gateway-package-matrix.mjs --profile all",
    "dev:server": "node scripts/run-drive-api-server.mjs server --dev-env-file .env.postgres",
    "server:plan": "node scripts/run-drive-api-server.mjs plan",
    "server:plan:postgres": "node scripts/run-drive-api-server.mjs plan --dev-env-file .env.postgres",
    "server:plan:sqlite": "node scripts/run-drive-api-server.mjs plan -- --database-url sqlite://target/dev/sdkwork-drive.sqlite",
    "test": "cargo test --workspace",
    "test:pc": "pnpm --dir apps/sdkwork-drive-pc test",
    "typecheck:pc": "pnpm --dir apps/sdkwork-drive-pc typecheck",
    "fmt:rust": "cargo fmt --all",
    "fmt:rust:check": "cargo fmt --all -- --check",
    "check:dependency-management": "node tools/check_sdkwork_drive_dependency_management.mjs",
    "check:drive-app-sdk-consumers": "node tools/check_drive_app_sdk_consumer_integration.mjs",
    "check:drive-pc-standard": "node tools/check_sdkwork_drive_pc_standard.mjs",
    "check:drive-package-standard": "node tools/check_sdkwork_drive_package_standard.mjs",
    "test:app-openapi-context": "node scripts/dev/sdkwork-drive-app-openapi-context.test.mjs",
    "sbom:generate": "node tools/generate_release_sbom.mjs",
    "verify": "cargo fmt --all -- --check && cargo test --workspace && cargo clippy --workspace --tests -- -D warnings && pnpm typecheck:pc && pnpm test:pc && node tools/check_sdkwork_drive_dependency_management.mjs && node tools/check_drive_app_sdk_consumer_integration.mjs && node tools/check_sdkwork_drive_pc_standard.mjs && node tools/check_sdkwork_drive_package_standard.mjs && node tools/generate_release_sbom.mjs"
  }
}
