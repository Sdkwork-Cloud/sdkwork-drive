    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --product-prefix drive",
    "check:agent-workflow-standard": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root .",
    "check:release-readiness": "node tools/check_sdkwork_drive_release_readiness.mjs",
    "api:check": "node tools/drive_sdk_generate.mjs --check",
    "api:envelope:check": "node tools/align_drive_app_api_openapi_envelope.mjs && node tools/align_drive_backend_openapi_envelope.mjs && node tools/materialize_drive_sdk_generator_input.mjs && node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "api:schema:check": "node tools/drive_schema_quality_gate.mjs",
    "api:materialize": "node tools/drive_sdk_generate.mjs --materialize && node tools/normalize_component_spec_roots.mjs",
    "sdk:check": "node tools/drive_sdk_generate.mjs --check",
    "sdk:generate": "node tools/drive_sdk_generate.mjs",
