    "deploy:plan:standalone": "pnpm exec sdkwork-app deploy:plan --deployment-profile standalone",
    "deploy:plan:cloud": "pnpm exec sdkwork-app deploy:plan --deployment-profile cloud",
    "deploy:apply": "pnpm exec sdkwork-app deploy:apply",
    "deploy:apply:standalone": "pnpm exec sdkwork-app deploy:apply --deployment-profile standalone",
    "deploy:apply:cloud": "pnpm exec sdkwork-app deploy:apply --deployment-profile cloud",
    "deploy:rollback": "pnpm exec sdkwork-app deploy:rollback",
    "deploy:rollback:standalone": "pnpm exec sdkwork-app deploy:rollback --deployment-profile standalone",
    "deploy:rollback:cloud": "pnpm exec sdkwork-app deploy:rollback --deployment-profile cloud",
    "deploy:validate": "pnpm exec sdkwork-app deploy:validate",
    "deploy:validate:standalone": "pnpm exec sdkwork-app deploy:validate --deployment-profile standalone",
    "deploy:validate:cloud": "pnpm exec sdkwork-app deploy:validate --deployment-profile cloud",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "api:assembly:materialize": "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
    "api:assembly:validate": "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root .",
    "db:postgres:init": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode init --config .env.postgres --app-root .",
    "db:postgres:plan": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode plan --config .env.postgres --app-root . --dry-run",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "_sdkwork:deploy:plan:standalone": "pnpm exec sdkwork-app deploy:plan --profile standalone.production",
    "_sdkwork:deploy:plan:cloud": "pnpm exec sdkwork-app deploy:plan --profile cloud.production",
    "_sdkwork:deploy:apply:standalone": "pnpm exec sdkwork-app deploy:apply --profile standalone.production",
    "_sdkwork:deploy:apply:cloud": "pnpm exec sdkwork-app deploy:apply --profile cloud.production",
    "_sdkwork:deploy:rollback:standalone": "pnpm exec sdkwork-app deploy:rollback --profile standalone.production",
    "_sdkwork:deploy:rollback:cloud": "pnpm exec sdkwork-app deploy:rollback --profile cloud.production",
    "_sdkwork:deploy:validate:standalone": "pnpm exec sdkwork-app deploy:validate --profile standalone.production",
    "_sdkwork:deploy:validate:cloud": "pnpm exec sdkwork-app deploy:validate --profile cloud.production",
    "dev:browser:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile standalone",
    "dev:desktop:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target desktop --deployment-profile standalone"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
