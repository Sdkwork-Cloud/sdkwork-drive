{
  "name": "sdkwork-drive",
  "private": true,
  "version": "0.1.0",
  "description": "SDKWork Drive backend workspace and PC application root.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "yaml": "^2.8.0"
  },
  "dependencies": {
    "@sdkwork/app-topology": "file:../sdkwork-app-topology"
  },
  "scripts": {
    "dev": "pnpm dev:browser",
    "dev:browser": "node scripts/sdkwork-command.mjs dev --runtime-target browser --database postgres --service-layout unified-process --deployment-profile standalone",
    "dev:desktop": "pnpm dev:desktop:postgres:unified-process:standalone",
    "dev:desktop:postgres:unified-process:standalone": "node scripts/sdkwork-command.mjs dev --runtime-target desktop --database postgres --service-layout unified-process --deployment-profile standalone",
    "dev:browser:sqlite": "node scripts/sdkwork-command.mjs dev --runtime-target browser --database sqlite --service-layout unified-process --deployment-profile standalone",
    "dev:desktop:sqlite": "node scripts/sdkwork-command.mjs dev --runtime-target desktop --database sqlite --service-layout unified-process --deployment-profile standalone",
    "build": "node scripts/sdkwork-command.mjs build --deployment-profile cloud",
    "build:standalone": "node scripts/sdkwork-command.mjs build --deployment-profile standalone",
    "build:debug": "node scripts/drive-build.mjs --deployment-profile standalone --debug",
    "test": "node scripts/sdkwork-command.mjs test",
    "check": "pnpm run check:app-composition && cargo check --workspace && pnpm check:architecture-alignment && pnpm check:dependency-management && pnpm check:app-sdk-consumers && pnpm check:package-standard && pnpm check:component-spec-standard && pnpm check:pc-standard && pnpm check:docs-standard && pnpm check:pnpm-script-standard && pnpm check:agent-workflow-standard && pnpm check:release-readiness && pnpm test:iam-application-bootstrap-standard && node ../sdkwork-specs/tools/audit-iam-embedded-bootstrap-workspace.mjs && pnpm deploy:validate && pnpm topology:validate && pnpm gateway:assembly:validate && pnpm db:validate && pnpm api:envelope:check && pnpm api:schema:check",
    "check:component-spec-standard": "node tools/normalize_component_spec_roots.mjs --check",
    "verify": "node scripts/sdkwork-verify.mjs && pnpm run check:app-composition",
    "clean": "node scripts/sdkwork-command.mjs clean",
    "typecheck": "pnpm --filter sdkwork-drive-pc typecheck",
    "test:pc": "pnpm --filter sdkwork-drive-pc test",
    "test:app-openapi-context": "node --test scripts/dev/sdkwork-drive-app-openapi-context.test.mjs",
    "test:app-sdk-smoke": "node --test sdks/sdkwork-drive-app-sdk/tests/sdk-family-smoke.test.mjs",
    "test:open-sdk-smoke": "node --test sdks/sdkwork-drive-sdk/tests/sdk-family-smoke.test.mjs",
    "test:backend-sdk-smoke": "node --test sdks/sdkwork-drive-backend-sdk/tests/sdk-family-smoke.test.mjs",
    "test:admin-storage-sdk-smoke": "node --test sdks/sdkwork-drive-admin-storage-sdk/tests/sdk-family-smoke.test.mjs",
    "test:sdk-ownership-boundaries": "node --test sdks/test/verify-sdk-ownership-boundaries.test.mjs",
    "test:database-framework-contract": "node --test tests/contract/database-framework.contract.test.mjs",
    "test:global-assets-contract": "node --test sdks/test/verify-global-assets-contract.test.mjs",
    "test:drive-integration": "node --test tests/integration/drive-alignment.integration.test.mjs",
    "test:iam-application-bootstrap-standard": "node scripts/dev/sdkwork-drive-iam-application-bootstrap-standard.test.mjs",
    "test:drive-share-link-integration": "node --test tests/integration/drive-share-link-flow.integration.test.mjs",
    "test:drive-e2e": "cargo test -p sdkwork-routes-drive-app-api --test share_link_cross_api_e2e",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.mjs",
    "test:release-evidence": "node --test tools/materialize_release_manifest_evidence.test.mjs",
    "check:architecture-alignment": "node tools/check_sdkwork_drive_architecture_alignment.mjs",
    "check:dependency-management": "node tools/check_sdkwork_drive_dependency_management.mjs",
    "check:app-sdk-consumers": "node tools/check_drive_app_sdk_consumer_integration.mjs",
    "check:package-standard": "node tools/check_sdkwork_drive_package_standard.mjs",
    "check:pc-standard": "node tools/check_sdkwork_drive_pc_standard.mjs",
    "check:docs-standard": "node ../sdkwork-specs/tools/check-repository-docs-standard.mjs --root .",
    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root . --product-prefix drive",
    "check:agent-workflow-standard": "node ../sdkwork-specs/tools/check-agent-workflow-standard.mjs --root .",
    "check:release-readiness": "node tools/check_sdkwork_drive_release_readiness.mjs",
    "api:check": "node tools/drive_sdk_generate.mjs --check",
    "api:envelope:check": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "api:schema:check": "node tools/drive_schema_quality_gate.mjs",
    "api:materialize": "node tools/drive_sdk_generate.mjs --materialize && node tools/normalize_component_spec_roots.mjs",
    "sdk:check": "node tools/drive_sdk_generate.mjs --check",
    "sdk:generate": "node tools/drive_sdk_generate.mjs",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_drive_baseline.sql --module-id drive --owner drive-platform --prefixes drive_ --engines postgres",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "gateway:run:standalone": "cargo run -p sdkwork-drive-standalone-gateway --bin sdkwork-drive-standalone-gateway",
    "gateway:plan:standalone": "node scripts/sdkwork-command.mjs gateway:plan --deployment-profile standalone",
    "gateway:build:standalone": "cargo build -p sdkwork-drive-standalone-gateway --bin sdkwork-drive-standalone-gateway",
    "gateway:validate:standalone": "cargo check -p sdkwork-drive-standalone-gateway",
    "gateway:matrix": "node scripts/sdkwork-command.mjs gateway:matrix",
    "gateway:package:standalone": "node scripts/sdkwork-command.mjs gateway:package:standalone",
    "gateway:package:cloud": "node scripts/sdkwork-command.mjs gateway:package:cloud",
    "release:plan": "node scripts/sdkwork-command.mjs release:plan",
    "release:build": "node scripts/sdkwork-command.mjs release:build",
    "release:package": "node scripts/sdkwork-command.mjs release:package",
    "release:validate": "node tools/check_sdkwork_drive_release_readiness.mjs && node tools/verify_release_evidence.mjs",
    "release:sbom": "node tools/generate_release_sbom.mjs",
    "release:evidence": "node tools/materialize_release_manifest_evidence.mjs",
    "release:web-bundle": "node scripts/release-web-bundle.mjs",
    "release:desktop-bundle": "node scripts/release-desktop-bundle.mjs",
    "release:catalog-media": "node scripts/release-catalog-media.mjs",
    "release:catalog-media-evidence": "node tools/materialize_catalog_media_evidence.mjs",
    "deploy:plan": "node scripts/sdkwork-command.mjs deploy:plan",
    "deploy:apply": "node scripts/sdkwork-command.mjs deploy:apply",
    "deploy:rollback": "node scripts/sdkwork-command.mjs deploy:rollback",
    "deploy:validate": "node scripts/sdkwork-command.mjs deploy:validate",
    "gateway:validate:cloud": "node scripts/gateway-cloud-bundle.mjs validate",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs",
    "db:postgres:init": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode init --config .env.postgres --app-root .",
    "db:postgres:plan": "node ../sdkwork-specs/tools/postgres/postgres-db-cli.mjs --mode plan --config .env.postgres --app-root . --dry-run",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root ."
  }
}
