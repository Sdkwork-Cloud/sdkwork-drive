{
  "license": "AGPL-3.0-or-later",
  "name": "sdkwork-drive",
  "private": true,
  "version": "0.1.0",
  "description": "SDKWork Drive backend workspace and PC application root.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "yaml": "^2.8.0"
  },
  "dependencies": {
    "@sdkwork/app-topology": "workspace:*"
  },
  "scripts": {
    "stop": "pnpm exec sdkwork-app stop",
    "dev": "pnpm dev:standalone",
