    "release:evidence": "node tools/materialize_release_manifest_evidence.mjs",
    "release:web-bundle": "node scripts/release-web-bundle.mjs",
    "release:desktop-bundle": "node scripts/release-desktop-bundle.mjs",
    "release:catalog-media": "node scripts/release-catalog-media.mjs",
    "release:catalog-media-evidence": "node tools/materialize_catalog_media_evidence.mjs",
