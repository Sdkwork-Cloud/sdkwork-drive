{
  "openapi": "3.1.2",
  "info": {
    "title": "SDKWork Drive Open API",
    "version": "0.1.0",
    "x-sdkwork-owner": "sdkwork-drive",
    "x-sdkwork-api-authority": "sdkwork-drive.open"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/open/v3/api/drive/share_links/{token}": {
      "get": {
        "tags": [
          "driveOpen"
        ],
        "operationId": "openShareLinks.resolve",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DriveOpenShareLink"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "410": {
            "description": "Gone",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        },
        "security": [],
        "x-sdkwork-owner": "sdkwork-drive",
        "x-sdkwork-api-authority": "sdkwork-drive.open"
      }
    },
    "/open/v3/api/drive/share_links/{token}/download_url": {
      "post": {
        "tags": [
          "driveOpen"
        ],
        "operationId": "openShareLinks.downloadUrls.create",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOpenDownloadUrlRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenDownloadUrlResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "410": {
            "description": "Gone",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        },
        "security": [],
        "x-sdkwork-owner": "sdkwork-drive",
        "x-sdkwork-api-authority": "sdkwork-drive.open"
      }
    }
  },
  "components": {
    "schemas": {
      "ProblemDetail": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status",
          "detail",
          "code",
          "traceId",
          "requestId"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "traceId": {
            "type": "string"
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "OpenNode": {
        "type": "object",
        "required": [
          "id",
          "tenantId",
          "spaceId",
          "nodeType",
          "nodeName"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "tenantId": {
            "type": "string"
          },
          "spaceId": {
            "type": "string"
          },
          "nodeType": {
            "type": "string"
          },
          "nodeName": {
            "type": "string"
          },
          "contentType": {
            "type": "string"
          },
          "contentLength": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "DriveOpenShareLink": {
        "type": "object",
        "required": [
          "id",
          "tenantId",
          "role",
          "downloadCount",
          "node"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "tenantId": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "expiresAtEpochMs": {
            "type": "integer",
            "format": "int64"
          },
          "downloadLimit": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "downloadCount": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "node": {
            "$ref": "#/components/schemas/OpenNode"
          }
        }
      },
      "CreateOpenDownloadUrlRequest": {
        "type": "object",
        "properties": {
          "requestedTtlSeconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600
          }
        }
      },
      "OpenDownloadUrlResponse": {
        "type": "object",
        "required": [
          "downloadUrl",
          "expiresAtEpochMs",
          "method"
        ],
        "properties": {
          "downloadUrl": {
            "type": "string"
          },
          "expiresAtEpochMs": {
            "type": "integer",
            "format": "int64"
          },
          "method": {
            "type": "string"
          }
        }
      }
    }
  },
  "x-sdkwork-owner": "sdkwork-drive",
  "x-sdkwork-api-authority": "sdkwork-drive.open"
}
