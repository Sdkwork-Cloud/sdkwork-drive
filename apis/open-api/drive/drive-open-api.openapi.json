  "components": {
    "schemas": {
      "ProblemDetail": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "type",
          "title",
          "status",
          "code",
          "traceId"
        ],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri-reference"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          },
          "code": {
            "$ref": "#/components/schemas/SdkWorkPlatformErrorCode"
          },
          "traceId": {
            "type": "string",
            "format": "uuid",
            "description": "Server-owned request correlation id."
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          }
        }
      },
      "FieldError": {
        "type": "object",
        "required": [
          "field",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "SdkWorkPlatformErrorCode": {
        "type": "integer",
        "format": "int32",
        "minimum": 40001,
        "maximum": 79999,
        "description": "Platform or domain error code per API_SPEC.md §15.3."
      },
      "SdkWorkApiResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "data",
          "traceId"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "enum": [
              0
            ],
            "default": 0,
            "minimum": 0,
            "maximum": 0
          },
          "data": {
            "description": "Operation-specific payload typed per response schema."
          },
          "traceId": {
            "type": "string",
            "format": "uuid",
            "description": "Server-owned request correlation id."
          }
        }
      },
      "SdkWorkResourceData": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item"
        ],
        "properties": {
          "item": {
            "type": "object",
            "additionalProperties": true,
            "description": "Typed domain resource for the operation."
          }
        }
      },
      "SdkWorkResourceResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "required": [
              "data"
            ],
            "properties": {
              "data": {
                "$ref": "#/components/schemas/SdkWorkResourceData"
              }
            }
          }
        ]
      },
      "OpenShareLinkResolveResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "required": [
                  "item"
                ],
                "properties": {
                  "item": {
                    "$ref": "#/components/schemas/DriveOpenShareLink"
                  }
                }
              }
            }
          }
        ]
      },
      "OpenDownloadUrlCreateResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SdkWorkApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "required": [
                  "item"
                ],
                "properties": {
                  "item": {
                    "$ref": "#/components/schemas/OpenDownloadUrlResponse"
                  }
                }
              }
            }
          }
        ]
      },
      "OpenNode": {
        "type": "object",
        "required": [
          "id",
          "tenantId",
          "spaceId",
          "nodeType",
          "nodeName"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "tenantId": {
            "type": "string"
          },
          "spaceId": {
            "type": "string"
          },
          "nodeType": {
            "type": "string"
          },
          "nodeName": {
            "type": "string"
          },
          "contentType": {
            "type": "string"
          },
          "contentLength": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "DriveOpenShareLink": {
        "type": "object",
        "required": [
          "id",
          "tenantId",
          "role",
          "downloadCount",
          "node"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "tenantId": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "expiresAtEpochMs": {
            "type": "integer",
            "format": "int64"
          },
          "downloadLimit": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "downloadCount": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "accessCodeRequired": {
            "type": "boolean"
          },
          "node": {
            "$ref": "#/components/schemas/OpenNode"
          }
        }
      },
      "CreateOpenDownloadUrlRequest": {
        "type": "object",
        "properties": {
          "requestedTtlSeconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600
          },
          "accessCode": {
            "type": "string",
            "minLength": 4,
            "maxLength": 64
          }
        }
      },
      "OpenDownloadUrlResponse": {
        "type": "object",
        "required": [
          "downloadUrl",
          "expiresAtEpochMs",
          "method"
        ],
        "properties": {
          "downloadUrl": {
            "type": "string"
          },
          "expiresAtEpochMs": {
            "type": "integer",
            "format": "int64"
          },
          "method": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Api-Key",
        "description": "API key for open-api access."
      }
    }
  },
  "x-sdkwork-owner": "sdkwork-drive",
  "x-sdkwork-api-authority": "sdkwork-drive.open"
}
